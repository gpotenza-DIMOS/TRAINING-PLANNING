import pandas as pd
import numpy as np

class TrainingPlanner:
    def __init__(self):
        # Database delle sedi disponibili e relativi costi fissi (affitto sala)
        self.sedi_aziendali = {
            "Firenze": {"costo_sala": 0, "capacita": 50, "lat_long": (43.82, 11.13)},
            "Falconara Marittima": {"costo_sala": 0, "capacita": 10, "lat_long": (43.62, 13.39)},
            "Roma": {"costo_sala": 225, "capacita": 20, "lat_long": (41.89, 12.49)}, 
            "Cantù": {"costo_sala": 0, "capacita": 10, "lat_long": (45.73, 9.12)},
            "Salerno": {"costo_sala": 400, "capacita": 30, "lat_long": (40.67, 14.78)}
        }
        
        # Parametri di costo (Personalizzabili)
        self.rimborso_km = 0.35  
        self.diaria_pranzo = 30.0
        self.costo_pernotto_cena = 120.0
        self.valore_giorno_uomo = 250.0 # Costo opportunità vendite perse
        self.df_pax = pd.DataFrame()

    def carica_partecipanti_manuale(self, lista_dati):
        self.df_pax = pd.DataFrame(lista_dati)
        return self.df_pax

    def calcola_distanza_approssimativa(self, citta_orig, citta_dest):
        # Matrice distanze semplificata A/R
        distanze = {
            ("Torino", "Cantù"): 320, ("Udine", "Cantù"): 700, ("Palermo", "Salerno"): 800,
            ("Ancona", "Firenze"): 400, ("Brescia", "Cantù"): 120, ("Modena", "Cantù"): 400,
            ("Milano", "Cantù"): 80, ("Roma", "Salerno"): 520, ("Cagliari", "Roma"): 600,
            ("Napoli", "Salerno"): 110, ("Foggia", "Salerno"): 350, ("Catanzaro", "Salerno"): 750,
        }
        # Cerca la combinazione o restituisce un valore medio di 500km se non trovata
        return distanze.get((citta_orig, citta_dest), distanze.get((citta_dest, citta_orig), 500))

    def analizza_scenario(self, sedi_scelte, giorni_training):
        if self.df_pax.empty:
            print("❌ Nessun dato caricato. Caricare Excel o dati manuali.")
            return

        totale_costi_vivi = 0
        totale_giornate_perse = 0
        
        # 1. Identifica i Relatori (sempre presenti)
        relatori = self.df_pax[self.df_pax['ruolo'].str.contains('Relatore', case=False, na=False)]
        partecipanti = self.df_pax[~self.df_pax['ruolo'].str.contains('Relatore', case=False, na=False)]
        
        print(f"--- ANALISI SCENARIO: {', '.join(sedi_scelte)} ({giorni_training} giorni) ---")
        
        # Suddivisione logica partecipanti per le sedi scelte
        chunks = np.array_split(partecipanti, len(sedi_scelte))
        
        for i, sede in enumerate(sedi_scelte):
            costo_sala = self.sedi_aziendali[sede]['costo_sala']
            totale_costi_vivi += costo_sala
            
            pax_in_sede = chunks[i]
            
            for _, row in pax_in_sede.iterrows():
                km = self.calcola_distanza_approssimativa(row['citta'], sede)
                costo_viaggio = km * self.rimborso_km
                
                # Check isole o distanze lunghe per pernotto
                isole = any(isla in str(row['citta']) for isla in ["Palermo", "Cagliari", "Sardegna", "Sicilia"])
                serve_pernotto = km > 450 or isole
                
                costo_pax = costo_viaggio + self.diaria_pranzo
                if serve_pernotto:
                    costo_pax += self.costo_pernotto_cena
                
                totale_costi_vivi += costo_pax
                totale_giornate_perse += giorni_training
                
        # Costi fissi Relatori (trasferte per ogni evento scelto)
        costo_viaggio_relatori = len(relatori) * len(sedi_scelte) * 150 
        totale_costi_vivi += costo_viaggio_relatori
        
        # Calcolo Impatto
        impatto_economico = totale_giornate_perse * self.valore_giorno_uomo
        
        print(f"✅ Costi Vivi (Viaggi, Hotel, Sale): €{totale_costi_vivi:.2f}")
        print(f"✅ Giornate Lavoro Perse Totali: {totale_giornate_perse}")
        print(f"✅ Costo Opportunità (Fatturato perso): €{impatto_economico:.2f}")
        print(f"💰 INVESTIMENTO TOTALE STIMATO: €{totale_costi_vivi + impatto_economico:.2f}")
        print("-" * 50)

# --- ESECUZIONE ---

planner = TrainingPlanner()

